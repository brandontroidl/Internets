# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg-link
*.egg
dist/
build/

# ── Virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/

# ── Linter / type-checker / test caches ──────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ── Build / supply-chain artefacts ───────────────────────────────────
# Generated by scripts/sbom.sh; regenerate per release, do not commit.
sbom.cdx.json
sbom.spdx.json

# ── IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Bot runtime files ────────────────────────────────────────────────
# Log files (main bot log + rotated copies).
*.log
# Tamper-evident admin-action audit log (separate from *.log convention,
# listed explicitly for clarity even though *.log already covers it).
audit.log
audit.log.*
# State persisted by store.Store — contains user PII, never commit.
locations.json
channels.json
users.json
# Per-module state file (modules/steam.py).
steamids.json
# Process lockfile from process_lock.py — never commit.
internets.pid

# ── Secrets and personal config ──────────────────────────────────────
# config.ini holds both bot settings and the [secrets] section
# (NickServ / SASL / server / oper passwords, API keys, the User-Agent
# email).  It's ignored so real credentials never get committed.
# config.ini.example is the credential-free template that lives in git.
#
# Other secret-store backends (any of these wins over the file):
#   - the OS keyring (no file artefact)
#   - INTERNETS_<NAME> env vars (sometimes via .env / .envrc)
config.ini
config.ini.tmp
config.ini.bak

# Legacy secret file from earlier versions — keep ignored so an
# unmigrated copy never ends up in git.
secrets.ini
secrets.ini.tmp
secrets.ini.bak

# Personal non-secret overrides (server hostname, modes, admin
# password hash).  Loaded on top of config.ini by config.py.
config.local.ini
config.local.ini.bak

# dotenv / direnv — common holders of INTERNETS_<NAME>=... secrets.
.env
.env.*
!.env.example
.envrc

# ── Merge / patch leftovers ──────────────────────────────────────────
*.bak
*.orig
*.rej

# ── Local diagnostic / scratch ───────────────────────────────────────
# Screenshots / paste-bins / one-off captures used during debugging.
# Useful locally; never meant for the repo.
screenshots/
