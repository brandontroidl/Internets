; ────────────────────────────────────────────────────────────────────
;  Internets bot secrets — TEMPLATE.
;
;  Copy this file to secrets.ini and chmod 600:
;
;      cp secrets.ini.example secrets.ini
;      chmod 600 secrets.ini
;      $EDITOR secrets.ini          # paste your real values
;
;  Or run:  python -m secret_store init      # does the above for you
;
;  secrets.ini is gitignored.  The bot refuses to read it if perms are
;  loose (anything other than 0600).  Only the file's owner can read
;  values from this file.
;
;  Alternatives (any backend wins over the file):
;    - environment variables:  INTERNETS_<NAME_UPPER>=value
;    - OS keyring (Keychain / Secret Service / CredMan):
;          pip install keyring
;          python -m secret_store set <name> --backend keyring
;
;  Visibility guarantees:
;    - The bot never logs the value of any field in this file.
;    - Outbound IRC messages are scrubbed for credential prefixes
;      (PASS, IDENTIFY, OPER, AUTHENTICATE) before being logged.
;    - `python -m secret_store get <name>` confirms presence only;
;      requires `--reveal` to print the actual value.
;    - `python -m secret_store list` shows backend per secret, not the
;      values themselves.
; ────────────────────────────────────────────────────────────────────

[secrets]

; ── IRC authentication ──────────────────────────────────────────────
; All four are sent reversibly on the wire — they CANNOT be hashed.
; The secret store gives encryption-at-rest; hashing would break auth.

; NickServ / SASL identify password (most networks use the same value).
nickserv_password =

; SASL PLAIN password — set this only if it differs from
; nickserv_password.  If empty, the bot falls back to nickserv_password.
sasl_password =

; PASS sent on connect, before NICK/USER.  Required by some bouncers.
server_password =

; /OPER password (oper_name lives in config.ini under [irc]).
oper_password =


; ── PII / contact identifier ────────────────────────────────────────
; Nominatim and several weather APIs require a real contact in the
; User-Agent.  Prefer a URL over an email when possible, e.g.
; "Internets/2.5.0 (https://github.com/youruser/yourrepo)".

weather_user_agent =


; ── Weather provider keys ───────────────────────────────────────────
; NWS and Open-Meteo need no key — leave them off this list.
; A provider with a missing key is silently inactive: its flag (e.g.
; -owm) is hidden from .help, and forcing it returns "not active".

; WeatherAPI.com — free tier: 1M calls/month
; https://www.weatherapi.com/signup.aspx
weatherapi_key =

; Tomorrow.io — free tier: 500 calls/day
; https://app.tomorrow.io/signup
tomorrowio_key =

; OpenWeatherMap — free tier: 60 calls/min, 1M calls/month
; https://home.openweathermap.org/users/sign_up
openweathermap_key =

; Visual Crossing — free tier: 1000 calls/day
; https://www.visualcrossing.com/sign-up
visualcrossing_key =

; Pirate Weather — free tier: 20,000 calls/month (Dark Sky replacement)
; https://pirateweather.net/getting-started
pirateweather_key =

; Weatherstack — free tier: 250 calls/month (current only)
; https://weatherstack.com/signup/free
weatherstack_key =

; Meteomatics — username + password (free trial available)
; https://www.meteomatics.com/en/sign-up-for-free-weather-api-test-account/
meteomatics_username =
meteomatics_password =

; AccuWeather — free tier: 50 calls/day
; https://developer.accuweather.com/user/register
accuweather_key =

; World Weather Online — free tier: 500 calls/day
; https://www.worldweatheronline.com/weather-api/
worldweatheronline_key =

; WeatherBit — free tier: 50 calls/day
; https://www.weatherbit.io/account/create
weatherbit_key =

; Stormglass (marine specialist) — free tier: 10 calls/day
; https://stormglass.io/sign-up
stormglass_key =

; Apple WeatherKit — Apple Developer Program (500K calls/month)
; Requires PyJWT + cryptography: pip install internets-irc[weatherkit]
; https://developer.apple.com/weatherkit/
weatherkit_team_id =
weatherkit_service_id =
weatherkit_key_id =
; weatherkit_key_file is a *path* to the .p8 private key file — kept
; outside this secrets file because it's typically owned by the bot
; user already.  Store the path, not the key contents.
weatherkit_key_file =


; ── Other module keys ───────────────────────────────────────────────
; A loaded module with a missing key shows no commands in .help.

; OMDb (movies)               — https://www.omdbapi.com/apikey.aspx
omdb_key =

; Last.fm                     — https://www.last.fm/api/account/create
lastfm_key =

; YouTube Data API v3         — https://console.cloud.google.com/apis/credentials
youtube_key =

; Stocks / crypto (any one of the three enables the module)
; Finnhub                     — https://finnhub.io/register
finnhub_key =
; Alpha Vantage               — https://www.alphavantage.co/support/#api-key
alphavantage_key =
; Twelve Data                 — https://twelvedata.com/account
twelvedata_key =

; Steam Web API               — https://steamcommunity.com/dev/apikey
steam_key =

; Twitch Helix                — https://dev.twitch.tv/console/apps
twitch_client_id =
twitch_client_secret =

; Brave Search (optional)     — https://brave.com/search/api/
;   .sw/.g fall back to DuckDuckGo if missing; image search needs Brave.
brave_key =
